# CloudOps Autopilot environment template
# Copy to .env and fill in real values for local or production execution.

# LIVE requires Azure authentication through DefaultAzureCredential and a real subscription.
CLOUD_MODE=LIVE
AZURE_SUBSCRIPTION_ID=<azure-subscription-id>

# Required for release-ready /ask-ai behavior and healthy AI readiness.
GEMINI_API_KEY=<gemini-api-key>
GEMINI_MODEL=gemini-2.5-flash

# Required for signed approval tokens.
JWT_SECRET_KEY=<strong-random-secret>
JWT_ALGORITHM=HS256
APPROVAL_TOKEN_ISSUER=cloudops-autopilot